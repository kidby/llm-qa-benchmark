# Copy to .env and fill in your key.

# OpenRouter gives access to every benchmarked model, and backs the LLM judges.
OPENROUTER_API_KEY=sk-or-...

# Optional: a local OpenAI-compatible server (Ollama or vLLM) for the "local" provider.
# Defaults to http://localhost:11434/v1, the Ollama default.
LOCAL_BASE_URL=http://localhost:11434/v1
LOCAL_API_KEY=ollama

# Optional: override the OpenRouter model used by the judges.
# JUDGE_MODEL=anthropic/claude-sonnet-4.6
